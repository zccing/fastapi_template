#!/bin/sh

# 命令失败或变量未设置时立即退出；解压后的归档可能包含敏感数据，
# 因此临时文件仅允许所有者读取。
set -eu
umask 077

: "${POSTGRES_USER:?POSTGRES_USER is required}"
: "${POSTGRES_DB:?POSTGRES_DB is required}"

backup_directory="${BACKUP_DIRECTORY:-/backups}"

if [ "$#" -ne 2 ] || [ "$2" != "--confirm-drop" ]; then
  printf 'Usage: %s <backup.dump[.gz]> --confirm-drop\n' "$0" >&2
  exit 2
fi

file_name="$1"
# 只接受文件名，防止用户输入逃逸出配置的备份目录。
case "$file_name" in
  "" | "." | ".." | */*)
    printf 'Backup must be a plain file name inside %s.\n' "$backup_directory" >&2
    exit 2
    ;;
esac

full_file_path="${backup_directory}/${file_name}"
if [ ! -f "$full_file_path" ] || [ ! -r "$full_file_path" ]; then
  printf 'Backup file is missing or unreadable: %s\n' "$file_name" >&2
  exit 1
fi

temporary_restore=""
cleanup() {
  if [ -n "$temporary_restore" ]; then
    rm -f -- "$temporary_restore"
  fi
}
trap cleanup 0
trap 'exit 1' HUP INT TERM

case "$file_name" in
  *.dump)
    restore_file="$full_file_path"
    ;;
  *.dump.gz)
    # 旧版 gzip 备份只解压一次，确保验证和恢复读取同一份归档；
    # 无论从哪个路径退出，EXIT trap 都会删除该临时文件。
    temporary_restore=$(mktemp "${TMPDIR:-/tmp}/postgres-restore.XXXXXX.dump")
    gzip -dc -- "$full_file_path" > "$temporary_restore"
    restore_file="$temporary_restore"
    ;;
  *)
    printf 'Backup file must end with .dump or .dump.gz.\n' >&2
    exit 2
    ;;
esac

# 在执行第一个破坏性命令前验证归档；读取归档目录无须连接目标数据库。
if ! pg_restore --list "$restore_file" >/dev/null; then
  printf 'Backup is not a valid PostgreSQL archive: %s\n' "$file_name" >&2
  exit 1
fi

printf 'Archive validated. Dropping database %s...\n' "$POSTGRES_DB"
dropdb --username="$POSTGRES_USER" -- "$POSTGRES_DB"

printf 'Creating a new database...\n'
createdb \
  --owner="$POSTGRES_USER" \
  --username="$POSTGRES_USER" \
  -- \
  "$POSTGRES_DB"

printf 'Applying the backup to the new database...\n'
# 数据库重建后，以单个事务恢复全部对象，避免 SQL 出错时留下部分恢复的数据。
pg_restore \
  --exit-on-error \
  --single-transaction \
  --username="$POSTGRES_USER" \
  --dbname="$POSTGRES_DB" \
  "$restore_file"

printf 'Backup applied successfully.\n'
