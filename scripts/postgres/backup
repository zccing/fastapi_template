#!/bin/sh

# 命令失败或变量未设置时立即退出；备份可能包含敏感数据，
# 因此本脚本创建的文件仅允许所有者读取。
set -eu
umask 077

: "${POSTGRES_USER:?POSTGRES_USER is required}"
: "${POSTGRES_DB:?POSTGRES_DB is required}"

backup_directory="${BACKUP_DIRECTORY:-/backups}"
mkdir -p -- "$backup_directory"

timestamp=$(date -u +%Y-%m-%d-%H%M%SZ)
backup_file=""
cleanup() {
  if [ -n "$backup_file" ]; then
    rm -f -- "$backup_file"
  fi
}

# 无论从哪个异常路径退出，都删除未完成的归档。信号处理器显式退出，
# 确保执行 EXIT trap，而不是让被中断的脚本继续运行。
trap cleanup 0
trap 'exit 1' HUP INT TERM

# 原子创建唯一文件，避免同一秒内并发或重试覆盖已有备份。
backup_file=$(mktemp "${backup_directory}/backup-${timestamp}.XXXXXX.dump")

printf 'Backup process started.\n'

pg_dump \
  --format=custom \
  --file="$backup_file" \
  --username="$POSTGRES_USER" \
  --dbname="$POSTGRES_DB"

# 读取归档目录即可验证 custom archive，无须连接数据库。
if ! pg_restore --list "$backup_file" >/dev/null; then
  printf 'Backup archive validation failed.\n' >&2
  exit 1
fi

# 归档已完成且验证通过，正常退出时不再删除。
trap - 0 HUP INT TERM
printf 'Backup has been created and validated: %s\n' "$backup_file"
