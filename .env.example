# PostgreSQL 异步连接地址；应用和 Alembic 迁移共用这一项，必须使用异步驱动。
DATABASE_ASYNC_URL=postgresql+asyncpg://app:app@localhost:5432/app

# 数据库连接池最多保留的连接数，取值范围为 1～256。
DATABASE_POOL_SIZE=16
# 连接进入池后允许复用的最长时间，单位为秒；1200 秒等于 20 分钟。
DATABASE_POOL_TTL=1200
# 每次从连接池取出连接前先检查可用性，可避免使用已被数据库关闭的旧连接。
DATABASE_POOL_PRE_PING=true

# 运行环境可选值：LOCAL、TESTING、STAGING、PRODUCTION。
ENVIRONMENT=LOCAL
# 应用版本号；部署环境会将其用于 FastAPI 的 root_path，例如 /v1。
APP_VERSION=1

# STAGING 和 PRODUCTION 环境必须配置；本地和测试环境可以不配置。
# SENTRY_DSN=https://public@example.ingest.sentry.io/project-id

# 允许跨域访问的前端 Origin，必须使用 JSON 数组格式。
CORS_ORIGINS=["http://localhost:3000"]
# Origin 正则只允许在 LOCAL 或 TESTING 环境使用；部署环境必须使用明确白名单。
# CORS_ORIGINS_REGEX=^https://.*\.example\.com$
# 浏览器跨域请求允许携带的请求头，必须使用 JSON 数组格式。
CORS_HEADERS=["Content-Type","Authorization","X-API-Key"]
# 只有 Cookie 等浏览器凭据确实参与认证时才启用；启用后禁止 wildcard Origin。
CORS_ALLOW_CREDENTIALS=false
